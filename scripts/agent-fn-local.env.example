# Copiar a scripts/agent-fn-local.env y completar. Ese archivo esta gitignoreado: NO se commitea.
#
# Son las 3 variables que Supabase le inyecta sola a cada edge fn cuando esta deployada.
# Corriendola local hay que darselas a mano.

# Project Settings -> API -> Project URL
SUPABASE_URL=https://cgdwieoxjoexzlfbxrfc.supabase.co

# Project Settings -> API -> Project API keys -> anon / public
SUPABASE_ANON_KEY=

# Project Settings -> API -> Project API keys -> service_role  ("Reveal")
#
# OJO: esta clave SALTEA RLS — puede leer y escribir cualquier tabla. Es la que usa la edge
# fn deployada, asi que para probar de verdad hace falta. Nunca la pongas en un VITE_* (eso
# la mandaria al browser), nunca la commitees, y no la pegues en un chat.
SUPABASE_SERVICE_ROLE_KEY=
