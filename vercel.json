{
  "buildCommand": "npm run build",
  "outputDirectory": "apps/operations/dist",
  "framework": null,
  "rewrites": [
    { "source": "/agendar", "destination": "/api/agendar" },
    { "source": "/agendar/p/:token", "destination": "/api/agendar?token=:token" },
    { "source": "/agendar/:slug", "destination": "/api/agendar?slug=:slug" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
